header.header
	.container.header__container
		.header__row
			a.header__logo(href="main.html" title="CryptoComes")
				img.header__logo-img(src="img/icons/logo.svg" alt="CryptoComes")

			.header__menu
				button.btn.btn--light.header__menu-close(aria-label="Close menu") Close

				.header__search
					form.header__search-form(action="#" method="get")
						input.input__elem.header__search-input(type="text" placeholder="Search" name="search")
						button.btn.btn--light.btn--search.header__search-submit(type="submit" aria-label="Send form")
							
				nav.header__nav(aria-label="Main navigation")
					ul.header__nav-list
						each category, i in nav
							li.header__nav-item
								a.header__nav-link(href="" + category.url)= category.name

			button.btn.btn--light.btn--burger.header__burger(aria-label="Open menu")